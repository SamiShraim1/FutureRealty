@model ServiceFormVM

@section Header {
     Edit Services
}

<div class="col-md-12">


    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Edit</h3>
        </div>


        <form asp-controller="Services" asp-action="Edit" enctype="multipart/form-data">
            <div class="card-body">
                <input type="hidden" asp-for="ImageName" />

                <input type="hidden" aasp-for="Id">
                <div class="form-group">
                    <label asp-for="Name">Service name</label>
                    <input asp-for="Name" class="form-control" placeholder="Enter the neme">
                </div>

                <div class="form-group">
                    <label asp-for="Description">Service Description</label>
                    <input asp-for="Description" class="form-control" placeholder="Enter the Description">
                </div>

                <div class="form-group">
                    <label asp-for="IsDeleted">@(Model.IsDeleted ? "The status is Deleted , do you want let it like this ?" : "The status is Active , Do you want to delete it?")</label>
                    <input asp-for="IsDeleted">
                    <span>yes</span>
                </div>
                <div class="form-group">
                    <label asp-for="Image"></label>
                    <input asp-for="Image" class="form-control-file" />
                </div>

            </div>

            <div class="card-footer">
                <button type="submit" class="btn btn-primary">Update</button>
            </div>
        </form>
    </div>
</div>